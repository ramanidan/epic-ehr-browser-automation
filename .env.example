# Epic EHR credentials
EPIC_BASE_URL=https://your-epic-instance.example.com
EPIC_USERNAME=your_username
EPIC_PASSWORD=your_password

# MFA (optional — TOTP secret from your authenticator app setup QR code)
EPIC_MFA_SECRET=

# SSO provider (native | okta | azure | saml)
EPIC_SSO_PROVIDER=native

# AnchorBrowser (cloud option — https://anchorbrowser.io)
ANCHORBROWSER_API_KEY=
